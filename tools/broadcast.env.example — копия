# Скопируйте этот файл в tools/.env.broadcast и подставьте значения.
# Скрипт сам подхватит tools/.env.broadcast или корневой .env (если есть).

# Обязательно: доступ к той же PostgreSQL, где лежит archive.users_<suffix>
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Для реальной отправки (или передайте --token в командной строке)
OLD_BOT_TOKEN=123456789:AA...ваш_токен_старого_бота

# Необязательно: суффикс архивной таблицы (имя archive.users_<SUFFIX>).
# Если не задан — берётся последняя запись из archive.migration_log.
# ARCHIVE_SUFFIX=20250512_abc123
